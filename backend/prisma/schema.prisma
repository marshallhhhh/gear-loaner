generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GearStatus {
  AVAILABLE
  CHECKED_OUT
  LOST
}

enum LoanStatus {
  ACTIVE
  RETURNED
}

enum Role {
  MEMBER
  ADMIN
}

model Profile {
  id        String   @id // Supabase auth user ID
  email     String   @unique
  fullName  String?
  role      Role     @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans   Loan[]
  actions Action[]
}

model Gear {
  id              String     @id @default(uuid())
  name            String
  description     String?
  // normalized relation to Category model
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  tags            String[]   @default([])
  serialNumber    String?    @unique
  shortId         String?    @unique
  loanStatus      GearStatus @default(AVAILABLE)
  qrCodeUrl       String?
  defaultLoanDays Int        @default(7)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  loans   Loan[]
  actions Action[]
}

// Optional dedicated categories table. Gear items still store a simple
// `category` string for backwards compatibility, but newly created/updated
// categories will be upserted here so the frontend can fetch the list
// efficiently via the `/gear/categories` endpoint.
model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // back-reference
  gears     Gear[]
}

model Loan {
  id           String     @id @default(uuid())
  gearItemId   String
  gearItem     Gear       @relation(fields: [gearItemId], references: [id])
  userId       String
  user         Profile    @relation(fields: [userId], references: [id])
  status       LoanStatus @default(ACTIVE)
  dueDate      DateTime
  checkoutDate DateTime   @default(now())
  returnDate   DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId])
  @@index([gearItemId])
  @@index([status])
}

enum ActionType {
  CHECKOUT
  RETURN
  REPORT_LOST
}

model Action {
  id         String     @id @default(uuid())
  type       ActionType
  userId     String?
  user       Profile?   @relation(fields: [userId], references: [id])
  gearItemId String
  gearItem   Gear       @relation(fields: [gearItemId], references: [id])
  latitude   Float?
  longitude  Float?
  details    Json?
  createdAt  DateTime   @default(now())

  @@index([gearItemId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}
