generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GearStatus {
  AVAILABLE
  CHECKED_OUT
  LOST
  RETIRED
}

enum LoanStatus {
  ACTIVE
  RETURNED
  CANCELLED
}

enum Role {
  MEMBER
  ADMIN
}

model Profile {
  id        String   @id // Supabase auth user ID
  email     String   @unique
  fullName  String?
  role      Role     @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans   Loan[]
  actions Action[]
}

model Gear {
  id              String     @id @default(uuid())
  name            String
  description     String?
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  tags            String[]   @default([])
  serialNumber    String?    @unique
  shortId         String?    @unique
  loanStatus      GearStatus @default(AVAILABLE)
  qrCodeUrl       String?
  defaultLoanDays Int        @default(7)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  loans   Loan[]
  actions Action[]
  @@index([loanStatus])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  gears     Gear[]
}

model Loan {
  id           String     @id @default(uuid())
  gearItemId   String
  gearItem     Gear       @relation(fields: [gearItemId], references: [id], onDelete: Cascade)
  userId       String
  user         Profile    @relation(fields: [userId], references: [id], onDelete: Restrict)
  status       LoanStatus @default(ACTIVE)
  dueDate      DateTime
  checkoutDate DateTime   @default(now())
  returnDate   DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([userId])
  @@index([gearItemId])
  @@index([status])
}

enum ActionType {
  CHECKOUT
  RETURN
  REPORT_FOUND
  ADMIN_REPORT_LOST
  ADMIN_MADE_AVAILABLE
  ADMIN_RETIRED
  ADMIN_UNRETIRED
  ADMIN_CANCELLED_LOAN
  ADMIN_MARK_FOUND
}

model Action {
  id         String     @id @default(uuid())
  type       ActionType
  userId     String?
  user       Profile?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  gearItemId String
  gearItem   Gear       @relation(fields: [gearItemId], references: [id], onDelete: Cascade)
  latitude   Float?
  longitude  Float?
  details    Json?
  createdAt  DateTime   @default(now())

  @@index([gearItemId])
  @@index([userId])
}